{
  "mcpServers": {
    "github": {
      "enabled": true,
      "type": "stdio",
      "command": "sh",
      "args": [
        "/app/.deploy/run_github_mcp.sh"
      ],
      "env": {},
      "description": "Official GitHub MCP server for repository, issues, pull requests, and workflow analysis"
    },
    "playwright": {
      "enabled": true,
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "mcr.microsoft.com/playwright/mcp"
      ],
      "env": {},
      "description": "Official Playwright MCP server for browser automation and live web validation"
    },
    "x-search": {
      "enabled": true,
      "type": "stdio",
      "command": "sh",
      "args": [
        "/app/.deploy/run_x_search_mcp.sh"
      ],
      "env": {
        "XAI_BASE_URL": "$XAI_BASE_URL",
        "XAI_X_SEARCH_MODEL": "$XAI_X_SEARCH_MODEL",
        "XAI_X_SEARCH_MAX_TURNS": "$XAI_X_SEARCH_MAX_TURNS",
        "XAI_X_SEARCH_TIMEOUT_SECONDS": "$XAI_X_SEARCH_TIMEOUT_SECONDS",
        "XAI_X_SEARCH_INLINE_CITATIONS": "$XAI_X_SEARCH_INLINE_CITATIONS"
      },
      "description": "xAI-backed X/Twitter search MCP server compatible with the OpenClaw x_search workflow"
    },
    "context7": {
      "enabled": true,
      "type": "stdio",
      "command": "sh",
      "args": [
        "/app/.deploy/run_context7_mcp.sh"
      ],
      "env": {},
      "description": "Official Context7 MCP server for version-aware library docs and code examples"
    },
    "tavily": {
      "enabled": true,
      "type": "stdio",
      "command": "sh",
      "args": [
        "/app/.deploy/run_tavily_mcp.sh"
      ],
      "env": {},
      "description": "Official Tavily MCP server for citation-friendly web discovery and research search"
    },
    "firecrawl": {
      "enabled": true,
      "type": "stdio",
      "command": "sh",
      "args": [
        "/app/.deploy/run_firecrawl_mcp.sh"
      ],
      "env": {},
      "description": "Official Firecrawl MCP server for deep extraction, crawl, scrape, and structured web research"
    },
    "cloudflare-api": {
      "enabled": true,
      "type": "stdio",
      "command": "sh",
      "args": [
        "/app/.deploy/run_cloudflare_mcp.sh"
      ],
      "env": {},
      "description": "Cloudflare API MCP tunneled through mcp-remote with shared production credentials"
    }
  },
  "skills": {
    "public:deep-research": {
      "enabled": true
    },
    "public:github-deep-research": {
      "enabled": true
    },
    "public:code-documentation": {
      "enabled": true
    },
    "public:data-analysis": {
      "enabled": true
    }
  }
}
